{
  "name": "@angular-wave/angular.ts",
  "description": "A modern, optimized and type-safe version of AngularJS",
  "license": "MIT",
  "version": "0.27.0",
  "type": "module",
  "main": "dist/angular-ts.esm.js",
  "module": "dist/angular-ts.esm.js",
  "browser": "dist/angular-ts.umd.js",
  "types": "@types/namespace.d.ts",
  "exports": {
    ".": {
      "types": "./@types/namespace.d.ts",
      "import": "./dist/angular-ts.esm.js",
      "default": "./dist/angular-ts.esm.js"
    },
    "./externs/angular.js": "./dist/externs/angular.js",
    "./runtime": {
      "types": "./@types/runtime/index.d.ts",
      "import": "./dist/runtime/index.js"
    },
    "./runtime/web-component": {
      "types": "./@types/runtime/web-component.d.ts",
      "import": "./dist/runtime/web-component.js"
    },
    "./runtime/*": {
      "types": "./@types/runtime/*.d.ts",
      "import": "./dist/runtime/*.js"
    },
    "./services/rest": {
      "types": "./@types/services/rest/rest.d.ts",
      "import": "./dist/services/rest/rest.js"
    },
    "./services/rest/*": {
      "types": "./@types/services/rest/*.d.ts",
      "import": "./dist/services/rest/*.js"
    },
    "./services/web-component": {
      "types": "./@types/services/web-component/web-component.d.ts",
      "import": "./dist/services/web-component/web-component.js"
    },
    "./services/webtransport": {
      "types": "./@types/services/webtransport/webtransport.d.ts",
      "import": "./dist/services/webtransport/webtransport.js"
    },
    "./directives/webtransport": {
      "types": "./@types/directive/webtransport/webtransport.d.ts",
      "import": "./dist/directive/webtransport/webtransport.js"
    },
    "./directives/repeat": {
      "import": "./dist/directive/repeat/repeat.js"
    },
    "./directives/*": {
      "import": "./dist/directive/*/*.js"
    },
    "./providers/controller": {
      "import": "./dist/core/controller/controller.js"
    }
  },
  "files": [
    "@types",
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/angular-wave/angular.ts.git"
  },
  "keywords": [
    "AngularJS",
    "AngularTS"
  ],
  "scripts": {
    "prepare": "husky",
    "prepack": "rm -rf .build dist @types && make build types"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@playwright/test": "latest",
    "@rollup/plugin-commonjs": "latest",
    "@rollup/plugin-node-resolve": "latest",
    "@rollup/plugin-terser": "latest",
    "@types/jasmine": "latest",
    "cssnano": "^7.1.1",
    "eslint": "9.28.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-promise": "^7.2.1",
    "globals": "^16.2.0",
    "husky": "^9.1.7",
    "jasmine-core": "latest",
    "nyc": "^14.1.1",
    "playwright": "latest",
    "postcss": "^8.5.6",
    "prettier": "latest",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "rollup": "latest",
    "rollup-plugin-version-injector": "latest",
    "typedoc": "^0.28.17",
    "typescript": "latest",
    "typescript-eslint": "^8.57.1",
    "vite": "latest",
    "vite-plugin-istanbul": "^8.0.0"
  }
}
