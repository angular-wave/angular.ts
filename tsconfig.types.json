{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "declaration": true,
    "allowJs": true,
    "emitDeclarationOnly": true,
    "stripInternal": true,
    "outDir": "@types",
    "noEmit": false,
    "incremental": false,
    "target": "ES2023"
  },
  "include": [
    "src/namespace.ts",
    "src/runtime/index.ts",
    "src/runtime/web-component.ts"
  ],
  "exclude": ["**/*.test.js", "**/*.spec.js"]
}
