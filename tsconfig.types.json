{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "declaration": true,
    "allowJs": true,
    "emitDeclarationOnly": true,
    "stripInternal": true,
    "outDir": "@types",
    "noEmit": false,
    "incremental": false,
    "target": "ES2023"
  },
  "include": [
    "src/auto.ts",
    "src/namespace.ts",
    "src/runtime/event-bus.ts",
    "src/runtime/html-canvas.ts",
    "src/runtime/index.ts",
    "src/runtime/orchestration.ts",
    "src/runtime/workflow-worker.ts",
    "src/runtime/realtime.ts",
    "src/runtime/router.ts",
    "src/runtime/service-worker.ts",
    "src/runtime/wasm.ts",
    "src/runtime/web-component.ts",
    "src/services/wasm/index.ts"
  ],
  "exclude": ["**/*.test.ts", "**/*.spec.ts"]
}
