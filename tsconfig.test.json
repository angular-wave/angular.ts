{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2023",
    "sourceMap": false,
    "declaration": false,
    "noUnusedLocals": false,
    "types": ["jasmine"]
  },
  "include": [
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "src/namespace.ts",
    "playwright-jasmine.d.ts"
  ]
}
