{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "incremental": true,
    "sourceMap": false,
    "declaration": false,
    "target": "ES2023"
  },
  "include": ["src"],
  "exclude": ["**/*.d.ts", "node_modules", "**/*.spec.ts", "**/*.test.ts"]
}
